# ============================================================
# MathAnimAI 环境变量配置
# 复制此文件为 .env 并填写实际值
# ============================================================

# === LLM大模型配置（本地Ollama / DeepSeek / 通义千问 / Anthropic Claude / 任何OpenAI兼容API）===
# Anthropic Claude（推荐，生成质量最好）
LLM_PROVIDER=anthropic
LLM_BASE_URL=https://api.kunkunout.cn/v1
LLM_API_KEY=sk-iSjOYOQIBI6jkrq5SJE47TvpoNPOPUE4Noek2BvkW55ica4O
LLM_MODEL=claude-opus-4-6

# 本地 Ollama（取消注释以切换）：
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5:7b

# 云端 API 备选（取消注释以切换）：
# LLM_PROVIDER=deepseek
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_API_KEY=your_deepseek_api_key
# LLM_MODEL=deepseek-chat

# === 渲染分辨率 ===
# 选项: "HD" (1920x1080) | "SD" (1280x720)
RENDER_QUALITY=HD

# === TTS语音配置 ===
# 中文女声: zh-CN-XiaoxiaoNeural (晓晓)
# 中文男声: zh-CN-YunxiNeural (云希)
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_RATE=+0%

# === 动画默认全局时长（秒） ===
ANIMATION_DURATION=1.0
SLIDE_DURATION=0.8

# === 存储路径 ===
OUTPUT_DIR=./output
CACHE_DIR=./cache

# === Gradio Web服务 ===
GRADIO_PORT=7060
GRADIO_SHARE=False
