      "name": "小学应用题 — 行程问题",
      "type": "word_problem",
      "grade": "小学",
      "problem": "小明从家到学校，每分钟走60米，需要15分钟。问小明家到学校有多远？",
      "script": {
        "problem_type": "word_problem",
        "grade_level": "小学",
        "problem_text": "小明从家到学校，每分钟走60米，需要15分钟。问小明家到学校有多远？",
        "final_answer": "900米",
        "settings": {
          "duration": 1.0,
          "slide_duration": 0.8,
          "auto_advance": true,
          "step_pause": 1.0
        },
        "base_figure": null,
        "coordinate_system": null,
        "steps": [
          {
            "step_number": 1,
            "title": "审题",
            "text": "小明从家到学校，每分钟走60米，需要15分钟。",
            "animation_type": "title_display",
            "position": "center",
            "voice_text": "我们来看这道应用题。小明从家到学校，每分钟走60米，需要15分钟。问家到学校有多远？",
            "math_expr": "",
            "config": {},
            "sub_steps": []
          },
          {
            "step_number": 2,
            "title": "提取关键信息",
            "text": "已知：速度 = 60米/分钟，时间 = 15分钟",
            "animation_type": "text_slide_in",
            "position": "below",
            "voice_text": "首先提取关键信息。已知速度是每分钟60米，时间是15分钟。",
            "math_expr": "v = 60, t = 15",
            "config": {},
            "sub_steps": []
          },
          {
            "step_number": 3,
            "title": "画线段图",
            "text": "用线段图表示路程关系",
            "animation_type": "draw_segment_diagram",
            "position": "below",
            "voice_text": "我们来画一个线段图，帮助理解路程关系。",
            "math_expr": "",
            "config": {
              "total": 15,
              "parts": [{"value": 15, "label": "15分钟 × 60米/分钟"}],
              "labels": ["家", "学校"]
            },
            "sub_steps": []
          },
          {
            "step_number": 4,
            "title": "应用公式",
            "text": "路程 = 速度 × 时间",
            "animation_type": "text_slide_in",
            "position": "below",
            "voice_text": "根据路程等于速度乘以时间的公式来计算。",
            "math_expr": "S = v \\times t",
            "config": {},
            "sub_steps": []
          },
          {
            "step_number": 5,
            "title": "计算",
            "text": "60 × 15 = 900（米）",
            "animation_type": "highlight",
            "position": "below",
            "voice_text": "60乘以15等于900米。",
            "math_expr": "60 \\times 15 = 900",
            "config": {},
            "sub_steps": []
          },
          {
            "step_number": 6,
            "title": "作答",
            "text": "答：小明家到学校有900米远。",
            "animation_type": "highlight",
            "position": "below",
            "voice_text": "所以小明家到学校有900米远。",
            "math_expr": "",
            "config": {},
            "sub_steps": []
          }
        ],
